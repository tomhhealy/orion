{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "composite": true,
    "sourceMap": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "types": ["node", "electron"],
    "lib": ["ES2023", "DOM"]
  },
  "include": [
    "src/**/*.ts",
    "forge.config.ts",
    "forge.env.d.ts",
    "vite.*.config.ts"
  ]
}
